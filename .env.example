# =============================================================
# Enterprise Knowledge Base — Environment Variables (template)
# =============================================================
# Copy this file to .env and fill in the values marked REQUIRED.
# Secrets (JWT_SECRET_KEY / ENCRYPTION_KEY) are auto-generated
# by ./install.sh on first run — do not edit by hand.
# =============================================================


# ---------- LLM Provider API Keys (fill at least one) ---------
# Built-in MiniMax provider. Leave empty to seed a placeholder key
# (live traffic will fail until you fill this in).
MINIMAX_API_KEY=

# Optional additional providers (add later via ./scripts/add-provider.sh
# or POST /api/v1/admin/providers). You do NOT need to put their keys here —
# the admin API encrypts and stores them in the database.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=


# ---------- Database (REQUIRED) -------------------------------
# PostgreSQL DSN used by the app container.
# The install.sh default matches docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://kb_user:kb_pass@postgres:5432/enterprise_kb


# ---------- Auto-generated secrets (leave blank) -------------
# install.sh writes fresh values on first run. Do not edit by hand
# unless you really know what you are doing.
JWT_SECRET_KEY=
ENCRYPTION_KEY=


# ---------- Server --------------------------------------------
HOST=0.0.0.0
PORT=8000
ENV=production


# ---------- CORS ---------------------------------------------
# Comma-separated. Add your frontend host if not on localhost:3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000


# ---------- Registration policy ------------------------------
# Set true only for dev / demo deployments. Production should stay false.
ALLOW_REGISTRATION=false
