# MiniMax API 配置（中国站）
MINIMAX_CN_API_KEY=your_minimax_cn_api_key

# 数据库（生产级 PostgreSQL）
DATABASE_URL=postgresql+asyncpg://postgres:@/enterprise_kb?host=/var/run/postgresql

# JWT 密钥（生产环境请更换为随机字符串，长度 ≥ 32 字符）
JWT_SECRET_KEY=change-me-in-production-use-a-random-secret

# 服务配置
HOST=0.0.0.0
PORT=8000

# 文档上传限制（默认 50MB）
UPLOAD_MAX_SIZE=52428800

# Docker Compose 部署时使用 TCP 连接
# DATABASE_URL=postgresql+asyncpg://kb_user:kb_pass@postgres:5432/enterprise_kb
